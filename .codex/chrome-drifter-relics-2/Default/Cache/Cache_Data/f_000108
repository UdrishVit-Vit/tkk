export default /* #__PURE__ */ JSON.parse("[\r\n    {\r\n        \"index\":  0,\r\n        \"type\":  \"paragraph\",\r\n        \"text\":  \"Шаман\",\r\n        \"bold\":  true\r\n    },\r\n    {\r\n        \"index\":  2,\r\n        \"type\":  \"paragraph\",\r\n        \"text\":  \"Зов духов\",\r\n        \"bold\":  true\r\n    },\r\n    {\r\n        \"index\":  3,\r\n        \"type\":  \"paragraph\",\r\n        \"text\":  \"Клан стоит в экстазе, пока напев худдулинши разносится сквозь лагерь юрт. Ее голос прекрасен и одновременно пугающе потусторонен, он словно искривляет саму реальность. Огонь горит жарче, ветер дует сильнее, и кажется, что звезды светят ярче. Время почти пришло. Она ожидает знамения на восходе солнца: тогда будет решено, придет ли война с восходом пылающего диска.\",\r\n        \"bold\":  false\r\n    },\r\n    {\r\n        \"index\":  4,\r\n        \"type\":  \"paragraph\",\r\n        \"text\":  \"Мороз пробрался сквозь лохмотья мор’хора. Знамение привело его сюда, в далекие края. В земли каменных домов и грязи. Тут они стыдят его. Тут они ставят под вопрос его дар. Но слезы все не могут перестать течь из его глаз, когда он умоляет людей, чтобы они бежали, покидали город, ведь так сказало знамение. На рассвете этого города не станет.\",\r\n        \"bold\":  false\r\n    },\r\n    {\r\n        \"index\":  5,\r\n        \"type\":  \"paragraph\",\r\n        \"text\":  \"Момент тишины до рассвета, когда маракиец замечает их всех — духов пустоты. Они прибыли помочь свершить правосудие над теми, кто посмел бросить вызов его крови. Сила духа неспешно наполняет его. Шаман медленно делает вдох, а затем выдыхает луч черной материи, который оборвет нити судьбы его врагов.\",\r\n        \"bold\":  false\r\n    },\r\n    {\r\n        \"index\":  6,\r\n        \"type\":  \"paragraph\",\r\n        \"text\":  \"Создание Шамана\",\r\n        \"bold\":  true\r\n    },\r\n    {\r\n        \"index\":  7,\r\n        \"type\":  \"paragraph\",\r\n        \"text\":  \"Создавая Шамана, подумайте, как он связан с духами? Слышал ли он их с детства? Поставили ли его на путь старейшины? Родились ли вы под великим знамением духов? Может, ваш персонаж всегда интересовался миром духов, и это поставило его на путь Шамана? Что-то произошло, после чего вы увидели духов? Великий дух разрушил ваш дом? Вы узрели, как дух ярости испепелил человека? Вас избрали, или вы сами решили встать на этот путь?\",\r\n        \"bold\":  false\r\n    },\r\n    {\r\n        \"index\":  8,\r\n        \"type\":  \"paragraph\",\r\n        \"text\":  \"Каких принципов вы придерживаетесь? Вы верите в абсолютную правду знамений? Вы когда-то нарушили табу своего клана? Почему вы в пути? Вы всегда верно интерпретировали знамения? Что вы ищете? Что вам нужно узнать, прежде чем вернуться?\",\r\n        \"bold\":  false\r\n    },\r\n    {\r\n        \"index\":  10,\r\n        \"type\":  \"table\",\r\n        \"rows\":  [\r\n                     [\r\n                         \"Быстрое созданиеВы можете быстро создать шамана, следуя этим подсказкам. Сделайте Телосложения самой высокой из ваших характеристик, второй по величине - Интеллект, третьей - Силу или Ловкость. Происхождение персонажа - отшельник, оазисный оборванец.\"\r\n                     ]\r\n                 ]\r\n    },\r\n    {\r\n        \"index\":  12,\r\n        \"type\":  \"paragraph\",\r\n        \"text\":  \"Таблица Шамана\",\r\n        \"bold\":  true\r\n    },\r\n    {\r\n        \"index\":  13,\r\n        \"type\":  \"table\",\r\n        \"rows\":  [\r\n                     [\r\n                         \"Уровень\",\r\n                         \"БонусУмений\",\r\n                         \"Умения\",\r\n                         \"Удержание духов\",\r\n                         \"Значение Кости Нитей\",\r\n                         \"Известныенапевы\",\r\n                         \"Ячейки напевов  на уровень напевов\"\r\n                     ],\r\n                     [\r\n                         \"\